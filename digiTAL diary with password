#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <unistd.h>
#define MAX_ENTRY 500
#define PASSFILE "pass.txt"
#define DIARYFILE "diary.txt"

// Function prototypes
int checkPassword();
void setPassword();
void addEntry();
void viewEntries();
void changePassword();

int main() {
    if(access(PASSFILE, F_OK) != 0) {
        printf("No password set. Please create one:\n");
        setPassword();
    }
    if (!checkPassword()) {
        printf("Access denied. Exiting.\n");
        exit(1);
    }

    int choice;
    do {
        printf("\n--- Digital Diary Menu ---\n");
        printf("1. Add Entry\n2. View Entries\n3. Change Password\n4. Exit\n");
        printf("Your choice: ");
        scanf("%d", &choice);
        getchar();
        switch(choice) {
            case 1: addEntry(); break;
            case 2: viewEntries(); break;
            case 3: changePassword(); break;
            case 4: printf("Goodbye!\n"); break;
            default: printf("Invalid choice.\n");
        }
    } while (choice != 4);
    return 0;
}

void setPassword() {
    char pass[100], pass2[100];
    printf("Create password: ");
    fgets(pass, sizeof(pass), stdin);
    pass[strcspn(pass, "\n")] = 0;

    printf("Confirm password: ");
    fgets(pass2, sizeof(pass2), stdin);
    pass2[strcspn(pass2, "\n")] = 0;

    if (strcmp(pass, pass2) != 0) {
        printf("Passwords do not match. Try again.\n");
        setPassword();
        return;
    }
    FILE *f = fopen(PASSFILE, "w");
    fprintf(f, "%s", pass);
    fclose(f);
    printf("Password set successfully.\n");
}

int checkPassword() {
    char pass[100], input[100];
    FILE *f = fopen(PASSFILE, "r");
    if (!f) return 0;
    fgets(pass, sizeof(pass), f);
    pass[strcspn(pass, "\n")] = 0;
    fclose(f);

    printf("Enter password: ");
    fgets(input, sizeof(input), stdin);
    input[strcspn(input, "\n")] = 0;

    return strcmp(pass, input) == 0;
}

void addEntry() {
    char entry[MAX_ENTRY];
    printf("Write your entry (max %d chars):\n", MAX_ENTRY);
    fgets(entry, sizeof(entry), stdin);

    time_t t = time(NULL);
    struct tm *tm = localtime(&t);
    char timestamp[20];
    strftime(timestamp, sizeof(timestamp), "%Y-%m-%d %H:%M:%S", tm);

    FILE *f = fopen(DIARYFILE, "a");
    fprintf(f, "[%s]\n%s\n\n", timestamp, entry);
    fclose(f);
    printf("Entry saved.\n");
}

void viewEntries() {
    FILE *f = fopen(DIARYFILE, "r");
    if (!f) {
        printf("No entries found.\n");
        return;
    }
    char line[600];
    while (fgets(line, sizeof(line), f)) {
        printf("%s", line);
    }
    fclose(f);
}

void changePassword() {
    if (!checkPassword()) {
        printf("Incorrect current password.\n");
        return;
    }
    setPassword();
}

